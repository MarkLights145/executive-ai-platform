// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id              String          @id @default(cuid())
  name            String
  openaiKeyRef    String?         // env var name only, never the key value
  createdAt       DateTime       @default(now())
  users           User[]
  projects        Project[]
  inviteCodes     InviteCode[]
  agentInstances  AgentInstance[]
  executionJobs   ExecutionJob[]
  escalations     Escalation[]
  usageLogs       UsageLog[]
}

model UsageLog {
  id            String   @id @default(cuid())
  orgId         String
  organization  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  jobId         String?   // optional link to ExecutionJob
  inputTokens   Int       @default(0)
  outputTokens  Int       @default(0)
  costEstimateCents Int?  // optional cost in cents
  createdAt     DateTime @default(now())
}

enum AgentAuthType {
  BEARER
}

model AgentInstance {
  id             String         @id @default(cuid())
  orgId          String
  organization   Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  name           String        // e.g. "LUTN Agent", "Markos Agent"
  baseUrl        String        // e.g. http://100.x.y.z:PORT or https://...
  authType       AgentAuthType @default(BEARER)
  authTokenRef   String        // env key name only, not the actual token
  enabled        Boolean       @default(true)
  createdAt      DateTime      @default(now())
  executionJobs  ExecutionJob[]
}

enum ExecutionJobStatus {
  PENDING
  RUNNING
  DONE
  ERROR
}

model ExecutionJob {
  id              String             @id @default(cuid())
  orgId           String
  organization    Organization      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  agentInstanceId String
  agentInstance   AgentInstance     @relation(fields: [agentInstanceId], references: [id], onDelete: Cascade)
  actorRole       String
  messageText     String
  status          ExecutionJobStatus @default(PENDING)
  resultText      String?
  errorText       String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
}

model InviteCode {
  id             String       @id @default(cuid())
  code           String       @unique
  role           String       @default("USER") // USER or ADMIN
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  expiresAt      DateTime
  usedAt        DateTime?
  createdAt      DateTime     @default(now())
}

model User {
  id                     String        @id @default(cuid())
  email                  String        @unique
  name                   String?
  passwordHash           String?      // for credentials login
  role                   String        @default("USER")
  organizationId         String
  organization           Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  telegramUserId         String?
  microsoftConnected     Boolean       @default(false)
  advisoryMode           Boolean      @default(true)
  onboardingPreferences  Json?         // checkboxes: inbox triage, calendar, etc.
  featureRequest         String?
  lastPingedAt           DateTime?     // when org admin last pinged this user
  createdAt              DateTime      @default(now())
  rundownSessions        RundownSession[]
  emailStates            EmailState[]
  assignedProjectTasks   ProjectTask[]   @relation("TaskAssignee")
  projectLeads           ProjectLead[]
}

model Project {
  id             String        @id @default(cuid())
  name           String
  description    String?
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  externalId     String?       // e.g. Square Pods project id for sync
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  tasks          ProjectTask[]
  projectLeads   ProjectLead[]
}

model ProjectLead {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  @@unique([projectId, userId])
}

model ProjectTask {
  id                 String    @id @default(cuid())
  projectId          String
  project            Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title              String
  description        String?
  status             String    @default("todo") // todo | in_progress | done
  assigneeId         String?
  assignee           User?     @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  order              Int       @default(0)
  lastStatusResponse String?
  lastStatusAt       DateTime?
  lastPingedAt       DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

model RundownSession {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  status         String   @default("active")
  resumePointer  String?
  createdAt      DateTime @default(now())
}

model EmailState {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  messageId String
  status    String   @default("pending")
}

enum EscalationStatus {
  OPEN
  ACKNOWLEDGED
  RESOLVED
}

model Escalation {
  id          String           @id @default(cuid())
  orgId       String
  organization Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  userId      String           // user who sent the off-script message
  messageText String
  reason      String           @default("OFF_SCRIPT") // OFF_SCRIPT or other
  status      EscalationStatus @default(OPEN)
  createdAt   DateTime         @default(now())
}
